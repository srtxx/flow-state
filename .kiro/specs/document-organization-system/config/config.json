{
  "scanner": {
    "includePaths": [
      ".agent",
      ".kiro",
      "backlog",
      "docs"
    ],
    "excludePaths": [
      "node_modules",
      ".git",
      "dist",
      "build",
      ".vercel",
      ".npm-cache"
    ],
    "fileExtensions": [".md", ".txt"]
  },
  "evaluator": {
    "weights": {
      "referenceCount": 0.4,
      "recency": 0.3,
      "size": 0.1,
      "category": 0.2
    },
    "thresholds": {
      "necessary": 60,
      "unnecessary": 30
    }
  },
  "output": {
    "outputPath": "DOCUMENT_ORGANIZATION_REPORT.md",
    "includeMetadata": true,
    "includeReasoningDetails": true
  }
}
