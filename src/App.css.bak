:root {
  /* --- Palette --- */
  --bg-app: #000000;
  --bg-card: #121212;
  --bg-subtle: #1E1E1E;

  --text-primary: #FFFFFF;
  --text-secondary: #A3A3A3;
  --text-tertiary: #525252;

  --accent-primary: #FFFFFF;
  --accent-surface: #262626;

  --status-good: #10B981;
  --status-warning: #F59E0B;
  --status-critical: #EF4444;

  /* --- Elevation (Shadows) --- */
  /* Minimized shadows for dark mode, relying more on borders */
  --shadow-sm: none;
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -2px rgba(0, 0, 0, 0.2);
  --shadow-floating: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.2);

  /* --- Shapes --- */
  --radius-sm: 8px;
  --radius-md: 16px;
  --radius-lg: 24px;
  --radius-full: 9999px;

  /* --- Typography --- */
  --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;

  /* --- Layout --- */
  --header-height: 60px;
  --bottom-nav-height: 80px;
  --max-width: 480px;

  /* --- Transitions --- */
  --transition-fast: 0.15s cubic-bezier(0.25, 0.8, 0.25, 1);
  --transition-base: 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  --transition-slow: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  --transition-bounce: 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);

  /* --- Spacing --- */
  --spacing-xs: 0.5rem;
  /* 8px */
  --spacing-sm: 0.75rem;
  /* 12px */
  --spacing-md: 1rem;
  /* 16px */
  --spacing-lg: 1.5rem;
  /* 24px */
  --spacing-xl: 2rem;
  /* 32px */
}

/* ============================================
   Reset & Base
   ============================================ */

*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  -webkit-tap-highlight-color: transparent;
  overscroll-behavior-y: none;
  /* Prevent pull-to-refresh on mobile */
  touch-action: manipulation;
  /* Improve touch response */
}

/* Ensure accessible tap targets */
button,
a {
  touch-action: manipulation;
  cursor: pointer;
}

/* Focus styles for accessibility */
button:focus-visible,
a:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
}

body {
  font-family: var(--font-sans);
  background-color: var(--bg-app);
  color: var(--text-primary);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  width: 100%;
  margin: 0;
  padding: 0;
}

#root {
  min-height: 100vh;
  min-height: 100dvh;
  width: 100%;
  max-width: 100vw;
  display: grid;
  place-items: center;
  overflow-x: hidden;
}

.app-container {
  width: 100%;
  max-width: var(--max-width);
  min-height: 100vh;
  min-height: 100dvh;
  background-color: var(--bg-app);
  box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
  position: relative;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* ============================================
   Layout Components
   ============================================ */

/* --- Header --- */
.header {
  height: calc(var(--header-height) + env(safe-area-inset-top));
  padding: env(safe-area-inset-top) 1rem 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(0, 0, 0, 0.85);
  /* Darker backdrop */
  /* Slightly more opaque */
  backdrop-filter: blur(16px);
  /* Stronger blur for premium feel */
  -webkit-backdrop-filter: blur(16px);
  position: sticky;
  top: 0;
  z-index: 100;
  /* Ensure it stays on top */
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

@media (min-width: 360px) {
  .header {
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }
}

.logo-flow {
  font-weight: 300;
  font-size: 1.125rem;
  letter-spacing: 0.02em;
}

.logo-state {
  font-weight: 700;
  font-size: 1.125rem;
  letter-spacing: 0.02em;
}

@media (min-width: 360px) {

  .logo-flow,
  .logo-state {
    font-size: 1.25rem;
  }
}

.sleep-button {
  background: var(--bg-card);
  padding: 0.5rem 0.875rem;
  min-height: 40px;
  border-radius: var(--radius-full);
  box-shadow: none;
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-base);
}

@media (min-width: 360px) {
  .sleep-button {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
}

.sleep-button:hover {
  background: var(--bg-subtle);
  transform: translateY(-1px);
  border-color: rgba(255, 255, 255, 0.2);
}

.sleep-button:active {
  transform: scale(0.95);
  background: var(--bg-subtle);
}

/* --- Main Content --- */
.main-content {
  flex: 1;
  padding: 0.875rem;
  padding-bottom: calc(var(--bottom-nav-height) + 2rem + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

@media (min-width: 360px) {
  .main-content {
    padding: 1rem;
  }
}

/* --- Bottom Nav (Floating Dock) --- */
.bottom-nav {
  position: fixed;
  bottom: calc(1.5rem + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  width: auto;
  min-width: min(280px, calc(100% - 2rem));
  /* Responsive min-width */
  max-width: calc(100% - 2rem);
  /* Reduced margin for small screens */
  background: rgba(18, 18, 18, 0.85);
  /* Dark dock */
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 0.75rem clamp(1rem, 3vw, 1.5rem);
  /* Responsive padding */
  border-radius: var(--radius-full);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: clamp(1rem, 3vw, 1.5rem);
  /* Responsive gap */
  box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.5);
  z-index: 100;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.nav-button {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.35rem;
  cursor: pointer;
  transition: all var(--transition-bounce);
  min-width: 44px;
}

.nav-button:hover:not(.active) {
  color: rgba(255, 255, 255, 0.6);
  transform: translateY(-2px);
}

.nav-button.active {
  color: #fff;
  transform: translateY(-4px);
}

.nav-button.active .nav-label {
  opacity: 1;
  font-weight: 600;
}

.nav-label {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  opacity: 0.8;
  transition: opacity var(--transition-base);
}

/* ============================================
   Dashboard Page
   ============================================ */

.score-display-large {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1.5rem 0;
  position: relative;
}

/* Circular ring or just clean text? Let's go clean text for now with big soft shadow */
.score-value-large {
  font-size: clamp(4rem, 12vw, 5.5rem);
  /* Responsive font size for small devices */
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.05em;
  background: linear-gradient(180deg, #FFFFFF 0%, #A3A3A3 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.3));
}

.score-label-small {
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: var(--text-secondary);
  margin-top: 0.5rem;
  text-transform: uppercase;
}

/* Status Indicator Pill */
.status-pill {
  margin-top: 0.875rem;
  background: var(--bg-card);
  padding: 0.4rem 0.875rem;
  border-radius: var(--radius-full);
  box-shadow: none;
  border: 1px solid rgba(255, 255, 255, 0.1);
  font-size: 0.8125rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

@media (min-width: 360px) {
  .status-pill {
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
}

.status-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background-color: var(--status-good);
  /* Default */
  flex-shrink: 0;
}

@media (min-width: 360px) {
  .status-dot {
    width: 8px;
    height: 8px;
  }
}

/* Chart Container */
.main-chart-container {
  margin: 1rem 0;
  padding: 0;
  height: clamp(220px, 40vh, 320px);
  /* Responsive height */
  width: 100%;
  max-width: 100%;
  overflow: hidden;
}

.chart-container-clean {
  width: 100%;
  height: 100%;
  max-width: 100%;
}

/* FAB */
.fab-button {
  position: fixed;
  bottom: calc(6rem + env(safe-area-inset-bottom));
  right: clamp(1rem, 3vw, 1.5rem);
  width: 56px;
  height: 56px;
  border-radius: 18px;
  background: var(--bg-card);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-floating);
  border: 1px solid rgba(255, 255, 255, 0.1);
  cursor: pointer;
  z-index: 90;
  transition: transform var(--transition-bounce), box-shadow var(--transition-base);
}

.fab-button:hover {
  transform: translateY(-2px) scale(1.05);
  box-shadow: 0 24px 30px -5px rgba(0, 0, 0, 0.4), 0 12px 12px -5px rgba(0, 0, 0, 0.2);
  border-color: rgba(255, 255, 255, 0.3);
}

.fab-button:active {
  transform: scale(0.9);
}

@media (min-width: 360px) {
  .fab-button {
    width: 60px;
    height: 60px;
    border-radius: 20px;
  }
}

/* ============================================
   Components & Cards
   ============================================ */

/* Generic Card */
.card-soft {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 0.875rem;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(255, 255, 255, 0.08);
  margin-bottom: 0.875rem;
  max-width: 100%;
  overflow: hidden;
}

@media (min-width: 360px) {
  .card-soft {
    padding: 1rem;
    margin-bottom: 1rem;
  }
}

/* List Items */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.875rem;
  background: var(--bg-card);
  margin-bottom: 0.75rem;
  border-radius: var(--radius-md);
  box-shadow: none;
  border: 1px solid rgba(255, 255, 255, 0.05);
  width: 100%;
  min-width: 0;
  gap: var(--spacing-xs);
  transition: all var(--transition-base);
}

.list-item:hover {
  background: var(--bg-subtle);
  transform: translateY(-1px);
  border-color: rgba(255, 255, 255, 0.15);
}

.item-content {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
  gap: 0.25rem;
}

.item-title {
  font-weight: 600;
  font-size: 1rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-primary);
}

.item-subtitle {
  font-size: 0.875rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Buttons */
.btn-primary {
  width: 100%;
  padding: 0.875rem;
  min-height: 52px;
  background: linear-gradient(135deg, var(--accent-primary), #E5E5E5);
  color: #000;
  /* Inverted for contrast against white accent */
  border-radius: var(--radius-lg);
  border: none;
  font-weight: 600;
  font-size: 0.9375rem;
  letter-spacing: 0.02em;
  cursor: pointer;
  transition: all var(--transition-slow);
  box-shadow: 0 4px 12px rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  position: relative;
  overflow: hidden;
}

@media (min-width: 360px) {
  .btn-primary {
    padding: 1rem;
    min-height: 56px;
    font-size: 1.05rem;
  }
}

.btn-primary::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(rgba(0, 0, 0, 0.1), transparent);
  opacity: 0;
  transition: opacity var(--transition-slow);
}

.btn-primary:hover::after {
  opacity: 0.5;
}

.btn-primary:active {
  transform: scale(0.96);
  box-shadow: 0 2px 8px rgba(255, 255, 255, 0.05);
}

.btn-primary:active::after {
  opacity: 1;
}

.btn-ghost {
  min-height: 44px;
  padding: 0.5rem 0.875rem;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-weight: 500;
  cursor: pointer;
  border-radius: var(--radius-md);
  transition: all var(--transition-base);
}

@media (min-width: 360px) {
  .btn-ghost {
    padding: 0.5rem 1rem;
  }
}

.btn-ghost:hover {
  background: var(--bg-subtle);
  color: var(--text-primary);
}

.btn-ghost:active {
  background: var(--accent-surface);
  transform: scale(0.98);
}

.btn-secondary {
  width: 100%;
  padding: 0.875rem;
  min-height: 52px;
  background: var(--bg-card);
  color: var(--text-primary);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(255, 255, 255, 0.1);
  font-weight: 600;
  font-size: 0.9375rem;
  cursor: pointer;
  transition: all var(--transition-base);
  box-shadow: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
}

@media (min-width: 360px) {
  .btn-secondary {
    padding: 1rem;
    min-height: 56px;
    font-size: 1rem;
  }
}

.btn-secondary:hover {
  background: var(--bg-subtle);
  border-color: rgba(255, 255, 255, 0.2);
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
}

.btn-secondary:active {
  background: var(--accent-surface);
  transform: scale(0.98);
  border-color: rgba(255, 255, 255, 0.25);
}

/* Toast Animations */
@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(100%);
  }

  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* Inputs */
.input-soft {
  width: 100%;
  padding: 0.875rem;
  border-radius: var(--radius-md);
  background: var(--bg-subtle);
  border: 1px solid rgba(255, 255, 255, 0.05);
  font-size: 1rem;
  margin-bottom: 0.875rem;
  transition: all var(--transition-base);
  color: var(--text-primary);
}

@media (min-width: 360px) {
  .input-soft {
    padding: 1rem;
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }
}

.input-soft:hover {
  border-color: rgba(255, 255, 255, 0.15);
}

.input-soft:focus {
  outline: none;
  border-color: var(--accent-primary);
  background: var(--bg-card);
  box-shadow: 0 0 0 1px var(--accent-primary);
}

/* ============================================
   Modal
   ============================================ */

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(4px);
  z-index: 1000;
  /* Ensure it's above Bottom Nav (100) and Header (100) */
  display: flex;
  align-items: flex-end;
  /* Bottom sheet on mobile */
  justify-content: center;
}

.modal-content {
  width: 100%;
  max-width: var(--max-width);
  background: var(--bg-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: clamp(1.25rem, 4vw, 2rem);
  /* Responsive padding */
  padding-bottom: calc(clamp(1.25rem, 4vw, 2rem) + env(safe-area-inset-bottom));
  box-shadow: var(--shadow-floating);
  animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  max-height: 90dvh;
  /* Increased for better mobile experience */
  overflow-y: auto;
  overflow-x: hidden;
  /* Prevent horizontal scroll */
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }

  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

@media (min-width: 360px) {
  .modal-header {
    margin-bottom: 2rem;
  }
}

.modal-title {
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

@media (min-width: 360px) {
  .modal-title {
    font-size: 1.5rem;
  }
}

/* Close button */
.btn-close {
  background: var(--bg-subtle);
  border: none;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: all var(--transition-base);
}

@media (min-width: 360px) {
  .btn-close {
    width: 36px;
    height: 36px;
  }
}

.btn-close:hover {
  background: var(--accent-surface);
  transform: scale(1.1);
}

.btn-close:active {
  transform: scale(0.95);
}

/* ============================================
   Utilities & Misc
   ============================================ */
.text-xs {
  font-size: 0.75rem;
}

.text-sm {
  font-size: 0.875rem;
}

.text-lg {
  font-size: 1.125rem;
}

.font-bold {
  font-weight: 700;
}

.text-secondary {
  color: var(--text-secondary);
}

.w-full {
  width: 100%;
}

.mt-2 {
  margin-top: 0.5rem;
}

.mt-4 {
  margin-top: 1rem;
}

.mb-4 {
  margin-bottom: 1rem;
}

.gap-2 {
  gap: 0.5rem;
}

.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.gap-1 {
  gap: 0.25rem;
}

.gap-2 {
  gap: 0.5rem;
}

.gap-3 {
  gap: 0.75rem;
}

.gap-4 {
  gap: 1rem;
}

.relative {
  position: relative;
}

.absolute {
  position: absolute;
}

.w-full {
  width: 100%;
}

.h-full {
  height: 100%;
}

/* Helper text classes */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.bg-bg-app {
  background-color: var(--bg-app);
}

.border-primary {
  border-color: var(--text-primary);
}

/* No Records State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 0.5rem;
}


.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

/* Pulse Animation */
@keyframes softPulse {
  0% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(0, 0, 0, 0.1);
  }

  70% {
    transform: scale(1);
    box-shadow: 0 0 0 10px rgba(0, 0, 0, 0);
  }

  100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(0, 0, 0, 0);
  }
}

/* ============================================
   Responsive Design
   ============================================ */

/* Journal Summary Card */
.journal-summary-card {
  position: sticky;
  top: calc(60px + env(safe-area-inset-top, 0px) + 0.5rem);
  z-index: 40;
}

/* Intake Modal Grid */
.intake-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
}

/* Small devices: 360px+ */
@media (min-width: 360px) {
  .intake-grid {
    gap: 1rem;
  }
}

/* Landscape mobile: 568px+ */
@media (min-width: 568px) and (orientation: landscape) {
  .intake-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .main-chart-container {
    height: clamp(180px, 35vh, 280px);
  }
}

/* Tablet: 768px+ */
@media (min-width: 768px) {
  :root {
    --max-width: 600px;
  }

  .main-content {
    padding: 2rem;
  }

  .grid-2 {
    gap: 1.5rem;
  }

  .card-soft {
    padding: 1.5rem;
  }

  .bottom-nav {
    width: calc(100% - 3rem);
    max-width: calc(var(--max-width) - 3rem);
    padding: 0.75rem 1.5rem;
  }

  .modal-content {
    border-radius: var(--radius-lg);
    max-width: 480px;
    margin: auto;
  }

  .intake-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  /* Journal grid - 2 columns on tablet */
  .journal-page .flex.flex-col.gap-3 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
}

/* Desktop: 1024px+ */
@media (min-width: 1024px) {
  :root {
    --max-width: 480px;
  }

  #root {
    background-color: var(--bg-subtle);
  }

  .app-container {
    margin: 1rem auto;
    border-radius: var(--radius-lg);
    min-height: calc(100vh - 2rem);
  }

  .bottom-nav {
    bottom: 2rem;
  }

  .intake-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

/* Extra small devices: max 320px */
@media (max-width: 320px) {
  .score-value-large {
    font-size: 3.5rem;
  }

  .bottom-nav {
    min-width: calc(100% - 1.5rem);
    padding: 0.5rem 0.75rem;
    gap: 0.5rem;
  }

  .nav-label {
    font-size: 0.6rem;
  }

  .fab-button {
    width: 52px;
    height: 52px;
    right: 1rem;
  }

  .modal-content {
    padding: 1rem;
    padding-bottom: calc(1rem + env(safe-area-inset-bottom));
  }

  .intake-grid {
    gap: 0.5rem;
  }

  .list-item {
    padding: 0.75rem;
  }

  .header {
    padding-left: 0.875rem;
    padding-right: 0.875rem;
  }

  .logo-flow,
  .logo-state {
    font-size: 1rem;
  }

  .sleep-button {
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    gap: 0.375rem;
  }

  .main-content {
    padding: 0.75rem;
  }

  .card-soft {
    padding: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .status-pill {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
    margin-top: 0.75rem;
  }

  .btn-primary,
  .btn-secondary {
    padding: 0.75rem;
    min-height: 48px;
    font-size: 0.875rem;
  }

  .modal-title {
    font-size: 1.125rem;
  }

  .modal-header {
    margin-bottom: 1.25rem;
  }
}

/* ============================================
   Dark Mode
   ============================================ */

@media (prefers-color-scheme: dark) {
  :root {
    /* --- Dark Palette --- */
    --bg-app: #121212;
    /* Lighter than #0a0a0a */
    --bg-card: #1E1E1E;
    /* Lighter than #1a1a1a */
    --bg-subtle: #2C2C2C;
    /* Lighter than #262626 */

    --text-primary: #fafafa;
    --text-secondary: #a3a3a3;
    --text-tertiary: #737373;

    --accent-primary: #ffffff;
    --accent-surface: #404040;

    /* Shadows adjusted for dark */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -2px rgba(0, 0, 0, 0.3);
    --shadow-floating: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
  }

  body {
    background-color: var(--bg-app);
    color: var(--text-primary);
  }

  #root {
    background-color: var(--bg-app);
  }

  .header {
    background: rgba(10, 10, 10, 0.8);
  }

  .sleep-button {
    background: var(--bg-card);
    border-color: rgba(255, 255, 255, 0.1);
    color: var(--text-primary);
  }

  .bottom-nav {
    background: rgba(250, 250, 250, 0.9);
  }

  .nav-button {
    color: rgba(0, 0, 0, 0.5);
  }

  .nav-button.active {
    color: #000;
  }

  .score-value-large {
    background: linear-gradient(180deg, #fafafa 0%, #a3a3a3 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.3));
  }

  .modal-overlay {
    background: rgba(0, 0, 0, 0.6);
  }

  .modal-content {
    background: var(--bg-card);
  }

  .btn-primary {
    background: var(--accent-primary);
    color: #000;
  }

  .btn-secondary {
    background: var(--bg-subtle);
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .input-soft {
    background: var(--bg-subtle);
    color: var(--text-primary);
  }

  .input-soft:focus {
    background: var(--bg-card);
    border-color: var(--accent-primary);
  }

  .btn-close {
    background: var(--bg-subtle);
    color: var(--text-primary);
  }

  /* Journal page dark adjustments */
  .journal-page .bg-white {
    background: var(--bg-card);
  }

  .journal-page .border-gray-100 {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .journal-page .text-gray-400,
  .journal-page .text-gray-500 {
    color: var(--text-secondary);
  }

  .journal-page .text-gray-800 {
    color: var(--text-primary);
  }

  .journal-page .bg-gray-50 {
    background: var(--bg-subtle);
  }

  /* Profile page dark adjustments */
  .profile-page .bg-gray-50,
  .profile-page .bg-gray-100 {
    background: var(--bg-subtle);
  }

  .profile-page .hover\:bg-gray-100:hover,
  .profile-page .hover\:bg-gray-200:hover {
    background: var(--accent-surface);
  }

  .profile-page .text-gray-500,
  .profile-page .text-gray-400 {
    color: var(--text-secondary);
  }

  .profile-page .text-gray-800 {
    color: var(--text-primary);
  }

  /* Modal adjustments for dark mode */
  .modal-content .bg-gray-100 {
    background: var(--bg-subtle);
  }

  .modal-content .text-gray-500 {
    color: var(--text-secondary);
  }

  .modal-content .bg-white {
    background: var(--bg-card);
  }

  .modal-content .border-gray-100,
  .modal-content .border-gray-300 {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .modal-content .hover\:border-gray-300:hover {
    border-color: rgba(255, 255, 255, 0.2);
  }

  .modal-content .hover\:bg-gray-50:hover {
    background: var(--bg-subtle);
  }

  /* Onboarding modal dark mode */
  .fixed.inset-0.bg-white {
    background: var(--bg-app) !important;
  }

  .fixed.inset-0 .bg-gray-50 {
    background: var(--bg-subtle);
  }

  .fixed.inset-0 .bg-gray-200 {
    background: var(--bg-subtle);
  }

  /* Intake modal quality selector dark mode */
  .modal-content button.bg-black {
    background: var(--accent-primary);
    color: #000;
  }

  .modal-content button.flex-1.bg-white {
    background: var(--bg-card);
    color: var(--text-secondary);
    border-color: rgba(255, 255, 255, 0.1);
  }
}